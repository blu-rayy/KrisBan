    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "docxtemplater": "^3.50.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "libreoffice-convert": "^1.7.0",
    "pizzip": "^3.2.0"
  },
