{
  "name": "pm-suite-backend",
  "version": "1.0.0",
  "description": "PM-Suite: Project Management Application Backend",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node --require dotenv/config src/server.js",
    "dev": "nodemon --require dotenv/config src/server.js",
    "seed": "node --require dotenv/config src/seed.js",
    "seed:progress": "node --require dotenv/config src/seed-progress-reports.js",
